


import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np





df=pd.read_csv("AAPL.csv")


df.head()


df.tail()


df.shape





df.isnull().sum()


df.duplicated().sum()





df1=df.reset_index()['Close']
df1.head()


df1.shape


plt.plot(df1)





from sklearn.preprocessing import MinMaxScaler
scaler=MinMaxScaler(feature_range=(0,1))
df1=scaler.fit_transform(np.array(df1).reshape(-1,1))


df1.shape


print(df1)





from sklearn.model_selection import train_test_split
train_data, test_data = train_test_split(df1, test_size=0.35, shuffle=False)


train_data.shape, test_data.shape





def create_dataset(dataset, time_step=1):
    X = [dataset[i:i+time_step, 0] for i in range(len(dataset)-time_step-1)]
    y = [dataset[i+time_step, 0] for i in range(len(dataset)-time_step-1)]
    return np.array(X), np.array(y)


time_step=100
X_train,y_train=create_dataset(train_data,time_step)
X_test,y_test=create_dataset(test_data,time_step)


print(X_train)


print(y_train)


print(X_test)


print(y_test)


X_train.shape, y_train.shape


X_test.shape, y_test.shape





X_train=X_train.reshape(X_train.shape[0],X_train.shape[1],1)
X_test=X_test.reshape(X_test.shape[0],X_test.shape[1],1)





from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense
from tensorflow.keras.layers import LSTM


model=Sequential()
model.add(LSTM(50,return_sequences=True,input_shape=(100,1)))
model.add(LSTM(50,return_sequences=True))
model.add(LSTM(50))
model.add(Dense(1))
model.compile(loss='mean_squared_error',optimizer='adam')


model.summary()


model.fit(X_train,y_train,validation_test=(X_test,y_test),epochs=100,batch_size=64,verbose=1)



